# Google Gemini API — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 解析截图用的视觉模型
GEMINI_PARSE_MODEL=gemini-2.5-flash
# 图像生成模型
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
DATABASE_URL=
NEXT_PUBLIC_APP_URL=https://ski.svgn.org

# Auth.js — 任意邮箱 Magic Link 登录
AUTH_SECRET=             # openssl rand -base64 32
EMAIL_SERVER_HOST=       # SMTP host, e.g. smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=       # SMTP user, e.g. resend
EMAIL_SERVER_PASSWORD=   # SMTP password / API key
EMAIL_FROM=noreply@svgn.org

# Stripe 按次收费
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_5=          # Stripe Price ID for 5-credit pack
STRIPE_PRICE_20=        # Stripe Price ID for 20-credit pack

# Vercel Blob — 分享图存储
BLOB_READ_WRITE_TOKEN=   # Vercel Dashboard → Storage → Blob → Settings
