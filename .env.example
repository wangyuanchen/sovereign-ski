OPENROUTER_API_KEY=
# 解析滑呗截图（视觉 → JSON），默认 google/gemini-2.5-flash
OPENROUTER_PARSE_MODEL=
# 第二步：朋友圈风格配图（图像生成，如 Google Nano Banana）
# 默认 google/gemini-2.5-flash-image；可改为 google/gemini-3.1-flash-image-preview 等
OPENROUTER_IMAGE_MODEL=
DATABASE_URL=
NEXT_PUBLIC_APP_URL=https://ski.svgn.org

# Auth.js — 任意邮箱 Magic Link 登录
AUTH_SECRET=             # openssl rand -base64 32
EMAIL_SERVER_HOST=       # SMTP host, e.g. smtp.resend.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=       # SMTP user, e.g. resend
EMAIL_SERVER_PASSWORD=   # SMTP password / API key
EMAIL_FROM=noreply@svgn.org

# Stripe 按次收费
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_5=          # Stripe Price ID for 5-credit pack
STRIPE_PRICE_20=        # Stripe Price ID for 20-credit pack
